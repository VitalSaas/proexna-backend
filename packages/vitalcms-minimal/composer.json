{
    "name": "vitalsaas/vitalcms-minimal",
    "description": "VitalCMS Minimal - Sistema de gestión de contenido minimalista para Laravel + Filament",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "cms", "filament", "content-management", "vitalsaas"],
    "authors": [
        {
            "name": "VitalSaaS",
            "email": "info@vitalsaas.com"
        }
    ],
    "homepage": "https://github.com/vitalsaas/vitalcms-minimal",
    "support": {
        "issues": "https://github.com/vitalsaas/vitalcms-minimal/issues",
        "source": "https://github.com/vitalsaas/vitalcms-minimal"
    },
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "filament/filament": "^4.0|^5.0",
        "spatie/laravel-sluggable": "^3.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "VitalSaaS\\VitalCMSMinimal\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VitalSaaS\\VitalCMSMinimal\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "VitalSaaS\\VitalCMSMinimal\\VitalCMSMinimalServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}