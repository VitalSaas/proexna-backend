# Ejemplo de variables de entorno
# Copia este archivo como .env.local y configura los valores

# URL base del sitio
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Información de contacto
NEXT_PUBLIC_CONTACT_EMAIL=info@jardineriaverde.com
NEXT_PUBLIC_CONTACT_PHONE=+1234567890
NEXT_PUBLIC_BUSINESS_NAME="Jardinería Verde"

# Configuración de formularios (opcional)
# EMAILJS_SERVICE_ID=tu_service_id
# EMAILJS_TEMPLATE_ID=tu_template_id
# EMAILJS_USER_ID=tu_user_id